@model List<Cubo>

<h1>Cubos Session</h1>
@if (Context.Session.GetString("IDSCUBOS") == null)
{
    <h1>No existen empleados</h1>
}
else{
@if (Model != null)
{
    <table class="table table-striped-colums">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Modelo</th>
                <th>Marca</th>
                <th>Imagen</th>
                <th>Precio</th>
            </tr>
        </thead>
        <tbody>

            @foreach (Cubo cubo in Model)
            {
                <tr>
                    <td>@cubo.IdCubo</td>
                    <td>@cubo.Nombre</td>
                    <td>@cubo.Modelo</td>
                    <td>@cubo.Marca</td>
                    <td>
                        <img src="~/images/cubos/@cubo.Imagen" style="width:50px;height:50px" />
                    </td>
                    <td>@cubo.Precio</td>
                    <td>
                        <a asp-asp-controller="Cubos" asp-action="CubosSession" asp-route-ideliminar="@cubo.IdCubo" class="btn btn-warning">Eliminar</a>
                    </td>
                </tr>
            }


        </tbody>
    </table>
}
}