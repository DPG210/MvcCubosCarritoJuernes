@model List<Cubo>

<h1>Cubos Session</h1>
@if (Context.Session.GetString("IDSCUBOS") == null)
{
    <h1>No existen empleados</h1>
}
else{
@if (Model != null)
{
    <table class="table table-striped-colums">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Modelo</th>
                <th>Marca</th>
                <th>Imagen</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>Subtotal</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>

                @foreach (var grupo in Model.GroupBy(x => x.IdCubo))
                {
                    
                    Cubo cubo = grupo.First();
                    int cantidad = grupo.Count();
                    int subtotal = cubo.Precio * cantidad;
                <tr>
                    <td>@cubo.IdCubo</td>
                    <td>@cubo.Nombre</td>
                    <td>@cubo.Modelo</td>
                    <td>@cubo.Marca</td>
                    <td>
                        <img src="~/images/cubos/@cubo.Imagen" style="width:50px;height:50px" />
                    </td>
                    <td>@cubo.Precio</td>
                    <td><strong>@cantidad</strong></td>
                    <td>@subtotal €</td>
                    <td>
                        <a asp-controller="Cubos" asp-action="CubosSession" asp-route-ideliminar="@cubo.IdCubo" class="btn btn-warning">Eliminar</a>
                    </td>
                </tr>
            }


        </tbody>
    </table>
        <h1>Total de prevcio: @Model.Sum(z => z.Precio)</h1>
        <form method="post" asp-route-accion="comprar">
            <button>Realizar carrito</button>
        </form>
}
}