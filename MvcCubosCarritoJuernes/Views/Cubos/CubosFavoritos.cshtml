@{
    List<Cubo> favoritos = memoryCache.Get<List<Cubo>>("FAVORITOS");
}

<h1>Favoritos</h1>
@if (favoritos != null)
{
    <table class="table table-striped-colums">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Modelo</th>
                <th>Marca</th>
                <th>Imagen</th>
                <th>Precio</th>
            </tr>
        </thead>
        <tbody>

            @foreach(Cubo cubo in favoritos)
            {
                <tr>
                    <td>@cubo.IdCubo</td>
                    <td>@cubo.Nombre</td>
                    <td>@cubo.Modelo</td>
                    <td>@cubo.Marca</td>
                    <td>
                        <img src="~/images/cubos/@cubo.Imagen" style="width:50px;height:50px" />
                    </td>
                    <td>@cubo.Precio</td>
                    <td>
                        <a asp-asp-controller="Cubos" asp-action="CubosFavoritos" asp-route-ideliminar="@cubo.IdCubo" class="btn btn-warning">Eliminar</a>
                    </td>
                </tr>
            }
            

        </tbody>
    </table>
}